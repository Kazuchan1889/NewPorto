# Copy this file to .env and fill in your values

# Supabase / PostgreSQL connection string (with pgbouncer for pooling)
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"

# (Optional) Only needed if frontend and API are on different origins
# FRONTEND_URL="https://your-vercel-domain.vercel.app"

# Local dev port for the Express server
PORT=3000
