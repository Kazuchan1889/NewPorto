{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"nodemon api/index.js\"",
    "server": "node api/index.js",
    "build": "node -e \"if (process.env.DATABASE_URL) { console.log('DATABASE_URL found, running migrations...'); require('child_process').execSync('npx sequelize-cli db:migrate', {stdio: 'inherit'}); } else { console.log('DATABASE_URL is missing. Skipping database migrations during build.'); }\" && vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "migrate": "npx sequelize-cli db:migrate",
    "migrate:undo": "npx sequelize-cli db:migrate:undo:all",
    "postinstall": "echo 'Sequelize Setup Done'"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "lucide-react": "^1.16.0",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.15.1",
    "recharts": "^3.8.1",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.0.3",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.45.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "nodemon": "^3.1.14",
    "postcss": "^8.4.38",
    "sequelize-cli": "^6.6.2",
    "tailwindcss": "^3.4.3",
    "vite": "^4.4.5"
  }
}
